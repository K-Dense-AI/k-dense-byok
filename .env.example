# Canonical deployment contract for K-Dense BYOK.
#
# This file is a placeholder-only reference for local operators, Docker/Compose,
# and Dokploy-managed environments.
#
# Non-Docker startup note:
# - The existing ./start.sh workflow still reads kady_agent/.env.
# - For local non-Docker runs, copy the values you need from this contract into
#   kady_agent/.env.
#
# Docker/Compose/Dokploy note:
# - Containerized deployment is optional.
# - Use these same variable names when wiring environment values through Compose
#   or Dokploy.

# -----------------------------------------------------------------------------
# Shared backend + LiteLLM secrets (required)
# Private: yes
# Dokploy-managed: yes in production
# Local-only default: no
# -----------------------------------------------------------------------------
OPENROUTER_API_KEY=your-openrouter-api-key
DEFAULT_AGENT_MODEL=openrouter/google/gemini-3.1-pro-preview
GOOGLE_GEMINI_BASE_URL=http://litellm:4000
GEMINI_API_KEY=sk-litellm-internal-placeholder

# -----------------------------------------------------------------------------
# Frontend public runtime variable
# Public: yes (safe to expose to the browser)
# Dokploy-managed: yes when frontend and backend do not share localhost
# Local-only default: optional because the current frontend falls back to
# http://localhost:8000 during the existing non-Docker workflow
# Use a browser-reachable backend URL here, not an internal service hostname like
# `http://backend:8000`
# -----------------------------------------------------------------------------
NEXT_PUBLIC_ADK_API_URL=http://localhost:8000

# -----------------------------------------------------------------------------
# Backend runtime configuration
# Private: yes
# Dokploy-managed: yes when frontend is served from a non-localhost origin
# Local-only default: optional because the backend already falls back to
# `http://localhost:3000` for the existing non-Docker workflow
# Use real browser-visible frontend origins here (localhost host ports or the
# public app domain), not internal container DNS names like `frontend`
# -----------------------------------------------------------------------------
BACKEND_CORS_ALLOWED_ORIGINS=http://localhost:3000,https://app.example.com

# -----------------------------------------------------------------------------
# Optional integrations
# Private: yes
# Dokploy-managed: optional
# Local-only default: optional
# -----------------------------------------------------------------------------
PARALLEL_API_KEY=your-parallel-api-key
MODAL_TOKEN_ID=your-modal-token-id
MODAL_TOKEN_SECRET=your-modal-token-secret
